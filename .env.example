# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ─────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your-helius-api-key    # for wallet activity checking
WALLET_ADDRESS=your-wallet-address    # track your own eligibility

# ─── Capital ─────────────────────────────────────────────────────────────────
TOTAL_CAPITAL_USD=5000
MIN_ESTIMATED_VALUE_USD=500
MIN_ROI=1.5

# ─── Chains ──────────────────────────────────────────────────────────────────
TRACKED_CHAINS=solana,base,arbitrum

# ─── Schedule ────────────────────────────────────────────────────────────────
REFRESH_INTERVAL_MS=86400000

# ─── Model ───────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5-20251001
